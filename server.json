{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ketiil/mcp-cmdb",
  "description": "MCP server connecting Claude to ServiceNow CMDB via natural language. Deep CMDB focus with relationship traversal, health auditing, dependency mapping, configurable inspection, and two-phase safe mutations.",
  "version": "0.1.1",
  "repository": {
    "url": "https://github.com/ketiil/mcp-cmdb",
    "source": "github"
  },
  "packages": [
    {
      "identifier": "servicenow-cmdb-mcp",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "registryType": "pypi",
      "runtimeHint": "uvx",
      "environmentVariables": [
        {
          "name": "SN_INSTANCE_URL",
          "description": "ServiceNow instance URL (e.g. https://your-instance.service-now.com)",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "SN_CLIENT_ID",
          "description": "OAuth 2.0 client ID from ServiceNow Application Registry",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "SN_CLIENT_SECRET",
          "description": "OAuth 2.0 client secret",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "SN_USERNAME",
          "description": "ServiceNow service account username",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "SN_PASSWORD",
          "description": "ServiceNow service account password",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
